#!/usr/bin/env bash
set -euo pipefail

if [[ -n "${GIT_CALL_LOG:-}" ]]; then
  echo "git $*" >> "$GIT_CALL_LOG"
fi

case "$1" in
  push)
    exit 0
    ;;
  commit)
    exit 0
    ;;
  config)
    exit 0
    ;;
  remote)
    if [[ "${2:-}" == "get-url" ]]; then
      echo "https://github.com/example/repo.git"
      exit 0
    fi
    exit 0
    ;;
  *)
    # Fall back to real git for other commands.
    if [[ -n "${GIT_REAL_BIN:-}" ]]; then
      "$GIT_REAL_BIN" "$@"
    else
      command git "$@"
    fi
    ;;
esac
